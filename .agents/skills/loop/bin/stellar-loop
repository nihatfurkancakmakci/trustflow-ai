#!/usr/bin/env bash
# stellar-loop — control plane for the stellar-build learning loop.
#
# The learning loop captures how you use stellar-build's skills (locally,
# never transmitted) and lets you compile those traces back into sharper
# skills. This CLI handles the deterministic parts; the actual optimize/bench
# reasoning is done by your agent (Claude Code / Codex) via /optimize-skills
# and /bench-skills.
#
#   stellar-loop status              what's installed, tracing + auto-tune state
#   stellar-loop stats               per-skill usage from your local traces
#   stellar-loop tail [n]            show the n most recent trace records
#   stellar-loop optimize [skill]    compile traces -> sharper skills
#   stellar-loop bench [skill]       measure skill quality (before/after)
#   stellar-loop restore <skill>     undo the last optimization for a skill
#   stellar-loop ingest-codex        backfill skill usage from Codex rollouts
#   stellar-loop clear [--all]       delete traces (--all also clears backups)
#   stellar-loop where               print the data directory
#
# The loop runs itself: a SessionStart hook auto-retunes your skills once enough
# new usage accumulates, and a UserPromptSubmit hook sharpens every prompt.
# Knobs (env):
#   STELLAR_BUILD_AUTO_OPTIMIZE=0          disable hands-free retune (ON by default; needs the claude CLI)
#   STELLAR_BUILD_NO_REPROMPT=1            disable the per-prompt sharpener (ON by default)
#   STELLAR_BUILD_OPTIMIZE_THRESHOLD=20    uses-since-last before retuning
#   STELLAR_BUILD_OPTIMIZE_COOLDOWN_HOURS=6
#   STELLAR_BUILD_NO_LOOP=1                disable the auto-trigger entirely
#   STELLAR_BUILD_NO_TRACE=1               disable capture entirely
#
# Everything lives under $STELLAR_HOME (default ~/.stellar). Nothing leaves
# your machine.
set -euo pipefail

STELLAR_HOME="${STELLAR_HOME:-$HOME/.stellar}"
TRACES="$STELLAR_HOME/traces"
BACKUPS="$STELLAR_HOME/backups"
BENCH="$STELLAR_HOME/bench"
OPTLOG="$STELLAR_HOME/optimizations.jsonl"
STATE="$STELLAR_HOME/state.json"
CLAUDE_SKILLS="$HOME/.claude/skills"
CODEX_SESSIONS="$HOME/.codex/sessions"

C_B=$'\033[1m'; C_D=$'\033[2m'; C_G=$'\033[0;32m'; C_Y=$'\033[1;33m'; C_C=$'\033[0;36m'; C_R=$'\033[0m'
say()  { printf "%s\n" "$*"; }
head_() { printf "\n  %s%s%s\n" "$C_B" "$1" "$C_R"; }

ensure_dirs() { mkdir -p "$TRACES" "$BACKUPS" "$BENCH"; }

trace_files() { find "$TRACES" -maxdepth 1 -name '*.jsonl' 2>/dev/null | sort; }

# Count skill ACTIVATIONS: one closed span (kind:"span") + legacy synchronous
# records (event:"skill_invoked", e.g. Codex). Per-turn records (kind:"turn")
# are sub-units of a span and are not counted here.
total_traces() {
  local n=0 f
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    n=$((n + $(grep -cE '"kind":"span"|"event":"skill_invoked"' "$f" 2>/dev/null || echo 0)))
  done < <(trace_files)
  echo "$n"
}

# Per-skill activation counts: "<count> <skill>" lines, descending. Counts only
# activation records (spans + legacy), not per-turn records. Pure grep/sed so it
# works with no node/jq present.
skill_counts() {
  trace_files | while IFS= read -r f; do
    [ -n "$f" ] || continue
    grep -E '"kind":"span"|"event":"skill_invoked"' "$f" 2>/dev/null \
      | grep -o '"skill":"[^"]*"' | sed 's/"skill":"//;s/"$//'
  done | sort | uniq -c | sort -rn
}

# Read a numeric/string field from state.json (node if present, grep fallback).
state_field() {
  local key="$1"
  [ -f "$STATE" ] || { echo ""; return; }
  if command -v node >/dev/null 2>&1; then
    node -e "try{const s=require('$STATE');const v=s['$key'];process.stdout.write(v==null?'':String(v))}catch(e){}" 2>/dev/null
  else
    grep -o "\"$key\":[^,}]*" "$STATE" 2>/dev/null | head -1 | sed 's/.*://;s/"//g'
  fi
}

cmd_where() { ensure_dirs; say "$STELLAR_HOME"; }

cmd_status() {
  ensure_dirs
  head_ "stellar-build learning loop"
  printf "  data dir      %s%s%s\n" "$C_C" "$STELLAR_HOME" "$C_R"
  local capture="on"
  [ -n "${STELLAR_BUILD_NO_TRACE:-}" ] && capture="${C_Y}off (STELLAR_BUILD_NO_TRACE set)${C_R}"
  printf "  capture       %s\n" "$capture"

  local hook_state="${C_Y}not registered${C_R}"
  if [ -f "$HOME/.claude/settings.json" ] && grep -q 'stellar/hooks/trace-skill.sh' "$HOME/.claude/settings.json" 2>/dev/null; then
    hook_state="${C_G}registered (Claude Code PostToolUse:Skill)${C_R}"
  fi
  printf "  trace hook    %s\n" "$hook_state"

  printf "  traces        %s skill activations (spans) across %s day(s)\n" \
    "$(total_traces)" "$(trace_files | wc -l | tr -d ' ')"

  local opt=0
  [ -f "$OPTLOG" ] && opt=$(grep -c '"event":"optimized"' "$OPTLOG" 2>/dev/null || echo 0)
  printf "  optimizations %s recorded\n" "$opt"

  # Auto-trigger state (auto-tune is ON by default).
  local mode="${C_G}auto (hands-free, default)${C_R}"
  case "${STELLAR_BUILD_AUTO_OPTIMIZE:-}" in 0|false|no|off) mode="nudge (auto disabled)";; esac
  [ -n "${STELLAR_BUILD_NO_LOOP:-}" ] && mode="${C_Y}off (STELLAR_BUILD_NO_LOOP set)${C_R}"
  local thr="${STELLAR_BUILD_OPTIMIZE_THRESHOLD:-20}"
  local since; since="$(state_field traces_since_optimize)"; since="${since:-0}"
  printf "  auto-tune     %s  ${C_D}(at %s uses; %s since last)${C_R}\n" "$mode" "$thr" "$since"

  # Auto-reprompt state (ON by default).
  local rp="${C_G}on (sharpens every prompt)${C_R}"
  case "${STELLAR_BUILD_NO_REPROMPT:-}" in 1|true|yes|on) rp="${C_Y}off (STELLAR_BUILD_NO_REPROMPT set)${C_R}";; esac
  local prof="no profile yet"; [ -f "$STELLAR_HOME/profile.md" ] && prof="${C_G}profile.md learned${C_R}"
  printf "  auto-reprompt %s  ${C_D}(%s)${C_R}\n" "$rp" "$prof"

  local codex="${C_Y}none yet${C_R}"
  [ -d "$CODEX_SESSIONS" ] && codex="${C_G}sessions present${C_R} ${C_D}(stellar-loop ingest-codex to backfill)${C_R}"
  printf "  codex         %s\n" "$codex"

  printf "\n  %sNext:%s stellar-loop stats   ·   /optimize-skills   ·   /bench-skills\n\n" "$C_D" "$C_R"
}

cmd_stats() {
  ensure_dirs
  head_ "Skill usage (local traces)"
  local total; total=$(total_traces)
  if [ "$total" = "0" ]; then
    printf "  %sNo traces yet.%s Use a few skills, then run this again.\n\n" "$C_D" "$C_R"
    printf "  %sTracing requires the PostToolUse hook (Claude Code) and node.%s\n\n" "$C_D" "$C_R"
    return
  fi
  printf "  %scount  skill%s\n" "$C_D" "$C_R"
  skill_counts | while read -r count name; do
    [ -n "$name" ] || continue
    printf "  %5s  %s\n" "$count" "$name"
  done
  printf "\n  %s%s total activations.%s Skills with >= 5 spans are good optimize candidates.\n\n" "$C_D" "$total" "$C_R"
}

cmd_tail() {
  ensure_dirs
  local n="${1:-10}"
  local latest; latest=$(trace_files | tail -1)
  if [ -z "$latest" ]; then say "No traces yet."; return; fi
  head_ "Last $n trace records ($latest)"
  tail -n "$n" "$latest"
  echo
}

# Drive the agent to do the real work. If the `claude` CLI is on PATH we run
# it headlessly; otherwise we print the prompt to paste into your session.
run_agent() {
  local prompt="$1"
  if command -v claude >/dev/null 2>&1; then
    printf "  %sRunning your agent headlessly...%s\n\n" "$C_D" "$C_R"
    claude -p "$prompt"
  else
    head_ "Run this in your agent (Claude Code / Codex)"
    printf "  %s%s%s\n\n" "$C_C" "$prompt" "$C_R"
    printf "  %sTip: install the Claude Code CLI to run it from here automatically.%s\n\n" "$C_D" "$C_R"
  fi
}

cmd_optimize() {
  ensure_dirs
  local target="${1:-}"
  if [ -n "$target" ]; then
    run_agent "/optimize-skills $target"
  else
    run_agent "Use the optimize-skills skill to compile my stellar-build usage traces into sharper skills."
  fi
}

cmd_bench() {
  ensure_dirs
  local extra="$*"
  run_agent "Use the bench-skills skill to benchmark my stellar-build skills. ${extra}"
}

cmd_restore() {
  ensure_dirs
  local skill="${1:-}"
  [ -n "$skill" ] || { say "Usage: stellar-loop restore <skill>"; exit 1; }
  local dir="$BACKUPS/$skill"
  if [ ! -d "$dir" ]; then say "No backups for '$skill'."; exit 1; fi
  local latest; latest=$(find "$dir" -name 'SKILL.md.*' 2>/dev/null | sort | tail -1)
  if [ -z "$latest" ]; then say "No SKILL.md backup found for '$skill'."; exit 1; fi
  local dest="$CLAUDE_SKILLS/$skill/SKILL.md"
  if [ ! -d "$CLAUDE_SKILLS/$skill" ]; then say "Skill '$skill' is not installed at $dest."; exit 1; fi
  cp -f "$latest" "$dest"
  # Mirror to codex if present.
  [ -d "$HOME/.codex/skills/$skill" ] && cp -f "$latest" "$HOME/.codex/skills/$skill/SKILL.md"
  printf "  %s✓%s Restored %s from %s\n" "$C_G" "$C_R" "$skill" "$(basename "$latest")"
}

cmd_clear() {
  ensure_dirs
  local all=false
  [ "${1:-}" = "--all" ] && all=true
  rm -f "$TRACES"/*.jsonl 2>/dev/null || true
  printf "  %s✓%s Cleared traces.\n" "$C_G" "$C_R"
  if $all; then
    rm -rf "$BACKUPS"/* 2>/dev/null || true
    : > "$OPTLOG" 2>/dev/null || true
    printf "  %s✓%s Cleared backups and optimization log.\n" "$C_G" "$C_R"
  fi
}

# Best-effort backfill of skill usage from Codex session rollouts. Live Codex
# tracing runs via ~/.codex/hooks.json; this recovers history from before the
# hook was installed (or sessions where it didn't fire). Deduped per file.
cmd_ingest_codex() {
  ensure_dirs
  head_ "Ingest Codex session rollouts"
  if [ ! -d "$CODEX_SESSIONS" ]; then
    printf "  %sNo Codex sessions at %s.%s\n\n" "$C_D" "$CODEX_SESSIONS" "$C_R"
    return
  fi
  local marker="$STELLAR_HOME/.codex_ingested"; touch "$marker"
  local added=0 files=0 roll name ts sess out day
  day=$(date -u +%Y-%m-%d); out="$TRACES/$day.jsonl"
  while IFS= read -r roll; do
    [ -n "$roll" ] || continue
    grep -qxF "$roll" "$marker" 2>/dev/null && continue
    files=$((files + 1))
    sess=$(basename "$roll")
    while IFS= read -r name; do
      [ -n "$name" ] || continue
      ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
      printf '{"ts":"%s","event":"skill_invoked","agent":"codex","skill":"%s","source":"codex-rollout","session":"%s"}\n' \
        "$ts" "$name" "$sess" >> "$out"
      added=$((added + 1))
    done < <(grep -ho '"skill":"[^"]*"' "$roll" 2>/dev/null | sed 's/"skill":"//;s/"$//')
    echo "$roll" >> "$marker"
  done < <(find "$CODEX_SESSIONS" -type f -name 'rollout-*.jsonl' 2>/dev/null | sort)
  printf "  Processed %s new rollout file(s); added %s skill record(s).\n" "$files" "$added"
  printf "  %sLive Codex tracing also runs via ~/.codex/hooks.json — this only backfills history.%s\n\n" "$C_D" "$C_R"
}

usage() {
  sed -n '2,31p' "$0" | sed 's/^# \{0,1\}//'
}

cmd="${1:-status}"; shift || true
case "$cmd" in
  status)   cmd_status ;;
  stats)    cmd_stats ;;
  tail)     cmd_tail "${1:-10}" ;;
  optimize) cmd_optimize "${1:-}" ;;
  bench)    cmd_bench "$@" ;;
  restore)  cmd_restore "${1:-}" ;;
  clear)    cmd_clear "${1:-}" ;;
  ingest-codex) cmd_ingest_codex ;;
  where)    cmd_where ;;
  help|-h|--help) usage ;;
  *) printf "Unknown command: %s\n\n" "$cmd"; usage; exit 1 ;;
esac
